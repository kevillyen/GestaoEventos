@model GestaoEventos.Models.Local

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h4 class="text-warning mb-3">
                <i class="fa-solid fa-pen-to-square me-2"></i>Editar Local
            </h4>
            <hr />
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Nome" class="form-control" placeholder="Nome do Local" />
                    <label asp-for="Nome"></label>
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Capacidade" class="form-control" placeholder="Capacidade do Local" />
                    <label asp-for="Capacidade"></label>
                    <span asp-validation-for="Capacidade" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning py-2 shadow-sm text-white fw-bold">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Salvar Alterações
                    </button>
                    <a asp-action="Index" class="btn btn-link text-muted">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>