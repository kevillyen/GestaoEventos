@model GestaoEventos.Models.Categoria

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h4 class="mb-3 text-success">
                <i class="fa-solid fa-folder-plus me-2"></i>Nova Categoria
            </h4>
            <hr />
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Corporativo, Festa, Workshop" />
                    <label asp-for="Nome"></label>
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success py-2 shadow-sm">
                        <i class="fa-solid fa-check me-1"></i> Salvar Categoria
                    </button>
                    <a asp-action="Index" class="btn btn-link text-muted">Voltar para a lista</a>
                </div>
            </form>
        </div>
    </div>
</div>