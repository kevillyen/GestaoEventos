@model IEnumerable<GestaoEventos.Models.Evento>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Eventos em Bariri</h1>
        <p class="lead">Fique por dentro do que acontece na sua região.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center">
                <div class="alert alert-light border shadow-sm">
                    <i class="fa-solid fa-calendar-xmark fa-2x mb-2 text-muted"></i>
                    <p>Nenhum evento programado para os próximos dias.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-shadow transition">
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">@item.Categoria?.Nome</span>
                            <h5 class="card-title fw-bold">@item.Nome</h5>
                            <p class="card-text text-muted">
                                <i class="fa-solid fa-calendar-day me-2 text-primary"></i>
                                @item.Data.ToLongDateString()
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <button class="btn btn-outline-primary w-100">Ver Detalhes</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }
</style>